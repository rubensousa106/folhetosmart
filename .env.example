# Copia para .env e preenche. O .env NÃO é commitado (está no .gitignore).

# --- IA (produtor) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Cloudflare R2 (produtor E backend) ---
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com   # SEM o /bucket no fim
R2_BUCKET=folhetosmart
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Backend ---
FOLHETO_JWT_SECRET=                  # openssl rand -base64 48
FOLHETO_BACKEND_URL=https://folhetosmart.onrender.com
FOLHETO_ADMIN_EMAIL=
FOLHETO_ADMIN_PASSWORD=

# --- Base de dados (backend: datasource; produtor: tokens FCM) ---
POSTGRES_DB=folhetosmart
POSTGRES_USER=folheto
POSTGRES_PASSWORD=folheto
DATABASE_URL=postgresql://folheto:folheto@localhost:5432/folhetosmart

# --- Notificações FCM (opcional) ---
FCM_PROJECT_ID=
FCM_CREDENTIALS_JSON=

# --- Aldi (folheto regional; por agora nacional) ---
ALDI_DISTRICT=Lisboa
ALDI_CITY=Lisboa

# --- Dev: redes com inspeção TLS (NUNCA em produção) ---
FOLHETO_INSECURE_TLS=0
