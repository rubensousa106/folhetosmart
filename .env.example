# =====================================================================
# FolhetoSmart — template de variáveis de ambiente.
# Copia para .env e preenche os valores reais. NÃO faças commit do .env.
# =====================================================================

# --- PostgreSQL ---
POSTGRES_DB=folhetosmart
POSTGRES_USER=folheto
POSTGRES_PASSWORD=troca-por-uma-password-forte

# --- Claude API (processamento centralizado: 1x/semana no servidor) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Aldi (folheto regional — zona usada pelo worker) ---
ALDI_DISTRICT=Lisboa
ALDI_CITY=Lisboa

# --- Google Drive (salvaguarda de folhetos PDF) ---
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_CREDENTIALS_PATH=credentials/gdrive_credentials.json

# --- Firebase Cloud Messaging (notificar utilizadores de folhetos novos) ---
FCM_PROJECT_ID=
FCM_CREDENTIALS_PATH=credentials/fcm_credentials.json

# --- Backend / Segurança ---
# Segredo JWT em base64 (>= 256 bits): openssl rand -base64 48
FOLHETO_JWT_SECRET=troca-isto-por-um-segredo-base64-de-32-bytes-no-minimo
# Produção: true (rejeita HTTP, exige TLS no proxy). Dev local: false.
FOLHETO_REQUIRE_HTTPS=false
# Rede com inspeção TLS (apenas dev). Nunca em produção.
FOLHETO_INSECURE_TLS=0

# --- Conta de administrador (criada/promovida no arranque) ---
# Necessária para os endpoints só-ADMIN (trigger/upload). Deixa vazio em dev.
FOLHETO_ADMIN_EMAIL=
FOLHETO_ADMIN_PASSWORD=

# --- Cron semanal interno ---
# true em local/docker (o backend dispara o worker); false no Render free
# (quem processa é o GitHub Actions).
FOLHETO_SCHEDULER_ENABLED=true
